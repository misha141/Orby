# Copy to `.env` in this folder (same directory as docker-compose.yml).
# Docker Compose loads it automatically for ${VAR} substitution in docker-compose.yml.
#
# CRITICAL: NEXT_PUBLIC_* is baked in at IMAGE BUILD time. After changing these:
#   docker compose build --no-cache frontend && docker compose up -d
#
# Use the URL the USER'S BROWSER will use to reach the API (not http://backend:4000).

# Local Docker on your laptop:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# FRONTEND_URL=http://localhost:3000

# EC2 with Nginx + Let's Encrypt:
# DOMAIN=orby.example.com
# SSL_EMAIL=you@example.com
# NEXT_PUBLIC_API_BASE_URL=https://orby.example.com/api
# FRONTEND_URL=https://orby.example.com

# HTTPS + domain (recommended in production):
# DOMAIN=orby.example.com
# SSL_EMAIL=you@example.com
# NEXT_PUBLIC_API_BASE_URL=https://orby.example.com/api
# FRONTEND_URL=https://orby.example.com

DOMAIN=orby.example.com
SSL_EMAIL=you@example.com
NEXT_PUBLIC_API_BASE_URL=https://orby.example.com/api
FRONTEND_URL=https://orby.example.com
NEXT_PUBLIC_SPEECH_LANG=en-IN
BACKEND_PORT=4000
FRONTEND_PORT=3000
